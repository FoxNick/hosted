name: "Android Full Platform Build PHP 8.5"

on:
  workflow_dispatch:
  schedule:
    - cron: "0 1 * * 5"

jobs:
  build-android:
    name: "PHP ${{ matrix.php-version }} for Android ${{ matrix.android-arch }}"
    runs-on: ubuntu-latest # Android 交叉编译必须在 Linux 环境下进行
    strategy:
      fail-fast: false
      matrix:
        php-version:
          - "8.5"
        android-arch:
          - "arm64-v8a"
          - "armeabi-v7a"
          - "x86_64"
          - "x86"
        include:
          - android-arch: "arm64-v8a"
            android-ndk-arch: "aarch64"
            android-api-level: "21"
          - android-arch: "armeabi-v7a"
            android-ndk-arch: "arm"
            android-api-level: "21"
          - android-arch: "x86_64"
            android-ndk-arch: "x86_64"
            android-api-level: "21"
          - android-arch: "x86"
            android-ndk-arch: "i686"
            android-api-level: "21"
        extension:
          - amqp,apcu,bcmath,bz2,calendar,ctype,curl,dba,dom,ds,event,exif,filter,fileinfo,ftp,gd,gettext,gmp,iconv,igbinary,imagick,imap,intl,ldap,mbstring,mbregex,memcache,mysqli,mysqlnd,pdo_mysql,opcache,openssl,pcntl,password-argon2,pdo,pgsql,pdo_pgsql,phar,posix,rar,protobuf,readline,redis,session,shmop,simdjson,simplexml,xml,snappy,soap,sockets,sodium,sqlite3,pdo_sqlite,sqlsrv,ssh2,swoole,swow,sysvmsg,sysvsem,sysvshm,tidy,tokenizer,uuid,uv,xhprof,xlswriter,xmlwriter,xmlreader,xsl,yac,yaml,zip,zlib,zstd
    
    steps:
      - name: "Checkout"
        uses: "actions/checkout@v4"

      - name: Setup Android NDK
        uses: nttld/setup-ndk@v1
        with:
          ndk-version: r26c
          add-to-path: true

      - name: Set Android Cross-Compile Environment
        run: |
          TOOLCHAIN="${ANDROID_NDK_HOME}/toolchains/llvm/prebuilt/linux-x86_64"
          API=${{ matrix.android-api-level }}
          ARCH=${{ matrix.android-ndk-arch }}
          
          if [ "$ARCH" = "aarch64" ]; then
            TARGET="aarch64-linux-android"
          elif [ "$ARCH" = "arm" ]; then
            TARGET="armv7a-linux-androideabi"
          elif [ "$ARCH" = "x86_64" ]; then
            TARGET="x86_64-linux-android"
          elif [ "$ARCH" = "i686" ]; then
            TARGET="i686-linux-android"
          fi
          
          export CC=$TOOLCHAIN/bin/${TARGET}${API}-clang
          export CXX=$TOOLCHAIN/bin/${TARGET}${API}-clang++
          export AR=$TOOLCHAIN/bin/llvm-ar
          export RANLIB=$TOOLCHAIN/bin/llvm-ranlib
          export LD=$TOOLCHAIN/bin/ld.lld
          
          echo "CC=$CC" >> $GITHUB_ENV
          echo "CXX=$CXX" >> $GITHUB_ENV
          echo "AR=$AR" >> $GITHUB_ENV
          echo "RANLIB=$RANLIB" >> $GITHUB_ENV
          echo "LD=$LD" >> $GITHUB_ENV
          echo "ANDROID_ARCH=${{ matrix.android-arch }}" >> $GITHUB_ENV

      - name: Download SPC bin
        uses: dawidd6/action-download-artifact@v3
        with:
          repo: crazywhalecc/static-php-cli
          branch: main
          workflow: release-build.yml
          name: "spc-linux-x86_64"

      - name: Validate SPC bin
        run: |
          chmod +x spc
          ./spc --version

      - id: cache-download
        uses: actions/cache@v4
        with:
          path: downloads
          key: php-${{ matrix.php-version }}-android-${{ matrix.android-arch }}-dependencies
      
      - name: "Download sources"
        env:
          GITHUB_TOKEN: ${{ secrets.S_GITHUB_TOKEN }}
        run: |
          ./spc download --with-php=${{ matrix.php-version }} --for-extensions=${{ matrix.extension }} --arch=${{ matrix.android-arch }}

      - name: "Build PHP for Android"
        run: |
          SPC_USE_SUDO=yes ./spc doctor --auto-fix
          
          # Android 仅支持编译 CLI 和 Micro，不支持 FPM；同时不支持 UPX 压缩
          BUILD_CMD="--build-cli --build-micro ${{ matrix.extension }} --debug --with-suggested-libs --with-suggested-exts --arch=${{ matrix.android-arch }}"
          
          echo "Executing: ./spc build $BUILD_CMD"
          ./spc build $BUILD_CMD

      - name: "Upload Artifacts"
        uses: actions/upload-artifact@v4
        with:
          name: php-${{ matrix.php-version }}-android-${{ matrix.android-arch }}
          path: |
            buildroot/bin/php
            buildroot/bin/micro.sfx
          retention-days: 7
